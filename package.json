{
    "name": "react-native-swipe-list-view",
    "version": "4.0.0-rc.0",
    "description": "A FlatList/SectionList with rows that swipe open and closed",
    "main": "lib/commonjs/index.js",
    "module": "lib/module/index.js",
    "types": "lib/typescript/index.d.ts",
    "source": "src/index.ts",
    "files": [
        "lib/",
        "src/",
        "CHANGELOG.md",
        "!**/__tests__"
    ],
    "sideEffects": false,
    "author": "Jesse Sessler <jesse.sessler@gmail.com>",
    "scripts": {
        "build": "bob build",
        "typecheck": "tsc --noEmit -p tsconfig.build.json",
        "lint": "eslint .",
        "test": "jest",
        "prettier": "prettier --write \"src/**/*.{ts,tsx}\"",
        "prepare": "bob build"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/jemise111/react-native-swipe-list-view.git"
    },
    "homepage": "https://jemise111.github.io/react-native-swipe-list-view/",
    "bugs": {
        "url": "https://github.com/jemise111/react-native-swipe-list-view/issues"
    },
    "license": "MIT",
    "keywords": [
        "react",
        "react-native",
        "react-component",
        "ios",
        "android",
        "flatlist",
        "sectionlist",
        "swipe",
        "swipeable"
    ],
    "peerDependencies": {
        "react": ">=18.0.0",
        "react-native": ">=0.73.0",
        "react-native-gesture-handler": ">=2.14.0",
        "react-native-reanimated": ">=3.6.0"
    },
    "devDependencies": {
        "@babel/core": "^7.25.0",
        "@react-native/babel-preset": "0.76.5",
        "@testing-library/react-native": "^12.8.0",
        "@types/jest": "^29.5.14",
        "@types/react": "^18.3.12",
        "eslint": "^9.14.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-react": "^7.37.2",
        "eslint-plugin-react-hooks": "^5.0.0",
        "jest": "^29.7.0",
        "prettier": "^3.3.3",
        "react": "18.3.1",
        "react-native": "0.76.5",
        "react-native-builder-bob": "^0.33.3",
        "react-native-gesture-handler": "^2.20.2",
        "react-native-reanimated": "^3.16.1",
        "react-test-renderer": "18.3.1",
        "typescript": "^5.6.3",
        "typescript-eslint": "^8.14.0"
    },
    "react-native-builder-bob": {
        "source": "src",
        "output": "lib",
        "targets": [
            "commonjs",
            "module",
            [
                "typescript",
                {
                    "project": "tsconfig.build.json"
                }
            ]
        ]
    }
}
